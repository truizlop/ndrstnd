// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`syntax-highlighted diff snapshots > uses the path-selected Shiki grammar and renders each file header once 1`] = `"<section id="diff" class="view"><p class="section-title">Every patch hunk</p><details class="file full-diff-file" open><summary><span class="file-path">src/example.ts</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -1,1 +1,1 @@</div><pre><span class="line deletion"><b>1</b><b></b><code><span class="diff-prefix">-</span><span style="color:#D73A49;--shiki-dark:#F97583">const</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#005CC5;--shiki-dark:#79B8FF">enabled</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#D73A49;--shiki-dark:#F97583">=</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#005CC5;--shiki-dark:#79B8FF">false</span><span style="color:#24292E;--shiki-dark:#E1E4E8">;</span></code></span><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span style="color:#D73A49;--shiki-dark:#F97583">export</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#D73A49;--shiki-dark:#F97583">const</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#005CC5;--shiki-dark:#79B8FF">enabled</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#D73A49;--shiki-dark:#F97583">=</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#005CC5;--shiki-dark:#79B8FF">true</span><span style="color:#24292E;--shiki-dark:#E1E4E8">;</span></code></span></pre></div></details><details class="file full-diff-file" open><summary><span class="file-path">scripts/example.py</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -2,0 +2,2 @@</div><pre><span class="line addition"><b></b><b>2</b><code><span class="diff-prefix">+</span><span style="color:#D73A49;--shiki-dark:#F97583">def</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#6F42C1;--shiki-dark:#B392F0">render</span><span style="color:#24292E;--shiki-dark:#E1E4E8">(name: </span><span style="color:#005CC5;--shiki-dark:#79B8FF">str</span><span style="color:#24292E;--shiki-dark:#E1E4E8">) -&gt; </span><span style="color:#005CC5;--shiki-dark:#79B8FF">str</span><span style="color:#24292E;--shiki-dark:#E1E4E8">:</span></code></span><span class="line addition"><b></b><b>3</b><code><span class="diff-prefix">+</span><span style="color:#24292E;--shiki-dark:#E1E4E8">    </span><span style="color:#D73A49;--shiki-dark:#F97583">return</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> </span><span style="color:#D73A49;--shiki-dark:#F97583">f</span><span style="color:#032F62;--shiki-dark:#9ECBFF">&quot;Hello, </span><span style="color:#005CC5;--shiki-dark:#79B8FF">{</span><span style="color:#24292E;--shiki-dark:#E1E4E8">name</span><span style="color:#005CC5;--shiki-dark:#79B8FF">}</span><span style="color:#032F62;--shiki-dark:#9ECBFF">&quot;</span></code></span></pre></div></details><details class="file full-diff-file" open><summary><span class="file-path">config/settings.json</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -1,0 +1,1 @@</div><pre><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span style="color:#24292E;--shiki-dark:#E1E4E8">{ </span><span style="color:#005CC5;--shiki-dark:#79B8FF">&quot;enabled&quot;</span><span style="color:#24292E;--shiki-dark:#E1E4E8">: </span><span style="color:#005CC5;--shiki-dark:#79B8FF">true</span><span style="color:#24292E;--shiki-dark:#E1E4E8"> }</span></code></span></pre></div></details></section>"`;
