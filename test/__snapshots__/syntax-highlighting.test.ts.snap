// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`syntax-highlighted diff snapshots > uses the path-selected Shiki grammar and renders each file header once 1`] = `"<section id="diff" class="view"><p class="section-title">Every patch hunk</p><details class="file full-diff-file" open><summary><span>▱ src/example.ts</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -1,1 +1,1 @@</div><pre><span class="line deletion"><b>1</b><b></b><code><span class="diff-prefix">-</span><span style="color:#D73A49">const</span><span style="color:#24292E"> </span><span style="color:#005CC5">enabled</span><span style="color:#24292E"> </span><span style="color:#D73A49">=</span><span style="color:#24292E"> </span><span style="color:#005CC5">false</span><span style="color:#24292E">;</span></code></span><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span style="color:#D73A49">export</span><span style="color:#24292E"> </span><span style="color:#D73A49">const</span><span style="color:#24292E"> </span><span style="color:#005CC5">enabled</span><span style="color:#24292E"> </span><span style="color:#D73A49">=</span><span style="color:#24292E"> </span><span style="color:#005CC5">true</span><span style="color:#24292E">;</span></code></span></pre></div></details><details class="file full-diff-file" open><summary><span>▱ scripts/example.py</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -2,0 +2,2 @@</div><pre><span class="line addition"><b></b><b>2</b><code><span class="diff-prefix">+</span><span style="color:#D73A49">def</span><span style="color:#24292E"> </span><span style="color:#6F42C1">render</span><span style="color:#24292E">(name: </span><span style="color:#005CC5">str</span><span style="color:#24292E">) -&gt; </span><span style="color:#005CC5">str</span><span style="color:#24292E">:</span></code></span><span class="line addition"><b></b><b>3</b><code><span class="diff-prefix">+</span><span style="color:#24292E">    </span><span style="color:#D73A49">return</span><span style="color:#24292E"> </span><span style="color:#D73A49">f</span><span style="color:#032F62">&quot;Hello, </span><span style="color:#005CC5">{</span><span style="color:#24292E">name</span><span style="color:#005CC5">}</span><span style="color:#032F62">&quot;</span></code></span></pre></div></details><details class="file full-diff-file" open><summary><span>▱ config/settings.json</span><small>modified</small></summary><div class="diff-block"><div class="diff-hunk-header">@@ -1,0 +1,1 @@</div><pre><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span style="color:#24292E">{ </span><span style="color:#005CC5">&quot;enabled&quot;</span><span style="color:#24292E">: </span><span style="color:#005CC5">true</span><span style="color:#24292E"> }</span></code></span></pre></div></details></section>"`;
