// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`syntax-highlighted diff snapshots > uses the path-selected Shiki grammar and renders each file header once 1`] = `"<section id="diff" class="view"><p class="section-title">Every patch hunk</p><details class="file full-diff-file" open data-file-id="typescript"><summary><span class="file-path">src/example.ts</span><small>modified</small></summary><div class="diff-block" data-diff-hunk="typescript-hunk"><div class="diff-hunk-header">@@ -1,1 +1,1 @@</div><pre><span class="line deletion"><b>1</b><b></b><code><span class="diff-prefix">-</span><span class="tk c0">const</span><span class="tk c1"> </span><span class="tk c2">enabled</span><span class="tk c1"> </span><span class="tk c0">=</span><span class="tk c1"> </span><span class="tk c2">false</span><span class="tk c1">;</span></code></span><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span class="tk c0">export</span><span class="tk c1"> </span><span class="tk c0">const</span><span class="tk c1"> </span><span class="tk c2">enabled</span><span class="tk c1"> </span><span class="tk c0">=</span><span class="tk c1"> </span><span class="tk c2">true</span><span class="tk c1">;</span></code></span></pre></div></details><details class="file full-diff-file" open data-file-id="python"><summary><span class="file-path">scripts/example.py</span><small>modified</small></summary><div class="diff-block" data-diff-hunk="python-hunk"><div class="diff-hunk-header">@@ -2,0 +2,2 @@</div><pre><span class="line addition"><b></b><b>2</b><code><span class="diff-prefix">+</span><span class="tk c0">def</span><span class="tk c1"> </span><span class="tk c3">render</span><span class="tk c1">(name: </span><span class="tk c2">str</span><span class="tk c1">) -&gt; </span><span class="tk c2">str</span><span class="tk c1">:</span></code></span><span class="line addition"><b></b><b>3</b><code><span class="diff-prefix">+</span><span class="tk c1">    </span><span class="tk c0">return</span><span class="tk c1"> </span><span class="tk c0">f</span><span class="tk c4">&quot;Hello, </span><span class="tk c2">{</span><span class="tk c1">name</span><span class="tk c2">}</span><span class="tk c4">&quot;</span></code></span></pre></div></details><details class="file full-diff-file" open data-file-id="json"><summary><span class="file-path">config/settings.json</span><small>modified</small></summary><div class="diff-block" data-diff-hunk="json-hunk"><div class="diff-hunk-header">@@ -1,0 +1,1 @@</div><pre><span class="line addition"><b></b><b>1</b><code><span class="diff-prefix">+</span><span class="tk c1">{ </span><span class="tk c2">&quot;enabled&quot;</span><span class="tk c1">: </span><span class="tk c2">true</span><span class="tk c1"> }</span></code></span></pre></div></details></section>"`;
