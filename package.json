{
  "name": "ndrstnd",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truizlop/ndrstnd.git"
  },
  "bin": {
    "ndrstnd": "dist/server/cli.js"
  },
  "scripts": {
    "dev": "tsx src/server/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir test",
    "pretest": "npm run rebuild:native",
    "test:watch": "vitest --dir test",
    "rebuild:native": "npm rebuild better-sqlite3",
    "lint": "npm run typecheck",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "preview:fixture": "tsx src/server/preview-fixture.ts"
  },
  "files": [
    "dist",
    "src/skill-assets",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "diff2html": "^3.4.56",
    "shiki": "^4.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
